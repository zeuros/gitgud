{
  "name": "gitgud",
  "version": "2.4.1",
  "description": "Get Gud at Git",
  "homepage": "https://github.com/zeuros/gitgud",
  "author": {
    "name": "zeuros"
  },
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "version": "node -e \"const fs=require('fs');['src-tauri/Cargo.toml','src-tauri/tauri.conf.json'].forEach(f=>{const c=fs.readFileSync(f,'utf8');fs.writeFileSync(f,c.replace(/version = \\\"[^\\\"]+\\\"/,'version = \\\"'+process.env.npm_new_version+'\\\"').replace(/\\\"version\\\": \\\"[^\\\"]+\\\"/,'\\\"version\\\": \\\"'+process.env.npm_new_version+'\\\"'))})\" && git add src-tauri/Cargo.toml src-tauri/tauri.conf.json",

    "start": "npm run tauri:dev",
    "ng:serve": "node --max-old-space-size=4096 ./node_modules/@angular/cli/bin/ng serve -c dev",
    "build:angular": "ng build --base-href ./",

    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux-deb": "tauri build --bundles deb",
    "tauri:build:linux-rpm": "tauri build --bundles rpm",
    "tauri:build:win": "tauri build --bundles nsis",
    "tauri:build:mac": "tauri build --bundles dmg",

    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:setup": "bash e2e/utils/setup-repo.sh",
    "e2e": "npm run e2e:setup && xvfb-maybe -- wdio run wdio.conf.ts",
    "e2e:debug": "npm run e2e:setup && WDIO_DEBUG=1 wdio run wdio.conf.ts --logLevel debug"
  },
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@mismerge/core": "^1.2.1",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@primeuix/themes": "^2.0.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "font-awesome": "4.7.0",
    "identicon.js": "^2.3.3",
    "lodash-es": "^4.18.1",
    "monaco-editor": "^0.55.1",
    "node-interval-tree": "2.1.2",
    "primeflex": "^4.0.0",
    "primeicons": "7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "7.8.2",
    "shiki": "^4.0.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@crabnebula/tauri-driver": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/mocha": "^10.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "tsx": "^4.19.0",
    "webdriverio": "^9.0.0",
    "@types/identicon.js": "^2.3.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.6.2",
    "css-loader": "^7.1.4",
    "eslint": "^10.3.0",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "npm-run-all": "4.1.5",
    "roughjs": "^4.6.6",
    "style-loader": "^4.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6",
    "wait-on": "9.0.5",
    "xvfb-maybe": "^0.2.1"
  }
}
