{
  "name": "gitgud",
  "version": "1.0.0",
  "description": "Gitgud",
  "homepage": "https://github.com/zeuros/gitgud",
  "author": {
    "name": "zeuros"
  },
  "main": "app/main.js",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "ng:serve": "node --max-old-space-size=4096 ./node_modules/@angular/cli/bin/ng serve -c dev",
    "build:angular": "ng build --base-href ./",
    "build:electron": "tsc -p tsconfig.serve.json",
    "build": "npm run build:electron && npm run build:angular",
    "build:prod": "npm run build -- -c production",
    "electron:serve": "wait-on tcp:4200 && npm run build:electron && electron . --serve",
    "start": "npm-run-all -p electron:serve ng:serve",
    "test:watch": "ng test",
    "e2e": "npm run build && playwright test -c e2e/playwright.config.ts e2e/",
    "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@electron/remote": "2.1.3",
    "@mismerge/core": "^1.2.1",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@primeuix/themes": "^2.0.3",
    "chokidar": "^5.0.0",
    "font-awesome": "4.7.0",
    "identicon.js": "^2.3.3",
    "lodash-es": "^4.18.1",
    "monaco-editor": "^0.55.1",
    "node-interval-tree": "2.1.2",
    "primeflex": "^4.0.0",
    "primeicons": "7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "7.8.2",
    "shiki": "^4.0.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@playwright/test": "1.59.1",
    "@types/identicon.js": "^2.3.5",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.6.2",
    "css-loader": "^7.1.4",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "eslint": "^10.3.0",
    "jest": "^30.4.2",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "npm-run-all": "4.1.5",
    "style-loader": "^4.0.0",
    "typescript": "~5.9.3",
    "wait-on": "9.0.5"
  },
  "build": {
    "publish": {
      "provider": "github"
    },
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "app/dist",
        "to": "dist"
      }
    ],
    "linux": {
      "maintainer": "zeuros <13236310+zeuros@users.noreply.github.com>",
      "category": "Development;RevisionControl;",
      "artifactName": "${productName}-${version}-Linux-${arch === 'x64' ? '64bit' : 'ARM64'}.${ext}",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "${productName}-${version}-Windows-Setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "artifactName": "${productName}-${version}-Mac-${arch === 'arm64' ? 'AppleSilicon-M1toM4' : 'Intel'}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
