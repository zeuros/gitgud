{
  "name": "gitgud",
  "version": "1.0.0",
  "description": "Gitgud",
  "homepage": "https://github.com/zeuros/gitgud",
  "author": {
    "name": "zeuros"
  },
  "main": "app/main.js",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "ng:serve": "ng serve -c dev",
    "build:angular": "ng build --base-href ./",
    "build:electron": "tsc -p tsconfig.serve.json",
    "build": "npm run build:electron && npm run build:angular",
    "build:prod": "npm run build -- -c production",
    "electron:serve": "wait-on tcp:4200 && npm run build:electron && electron . --serve",
    "start": "npm-run-all -p electron:serve ng:serve",
    "test:watch": "ng test",
    "e2e": "npm run build && playwright test -c e2e/playwright.config.ts e2e/",
    "e2e:show-trace": "playwright show-trace e2e/tracing/trace.zip",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/language-service": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@electron/remote": "2.1.3",
    "@primeuix/themes": "^2.0.3",
    "chokidar": "^5.0.0",
    "font-awesome": "4.7.0",
    "identicon.js": "^2.3.3",
    "lodash-es": "^4.17.23",
    "monaco-editor": "^0.55.1",
    "node-interval-tree": "2.1.2",
    "primeflex": "^3.3.1",
    "primeicons": "7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.4",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@playwright/test": "1.58.2",
    "@types/identicon.js": "^2.3.5",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.3.5",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "conventional-changelog-cli": "5.0.0",
    "css-loader": "^7.1.4",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "electron-debug": "4.1.0",
    "electron-reloader": "1.2.3",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "jest": "^30.3.0",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "node-polyfill-webpack-plugin": "4.1.0",
    "npm-run-all": "4.1.5",
    "playwright": "1.58.2",
    "style-loader": "^4.0.0",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "wait-on": "8.0.5",
    "webdriver-manager": "12.1.9"
  },
  "build": {
    "linux": {
      "maintainer": "zeuros <13236310+zeuros@users.noreply.github.com>",
      "target": [
        "deb"
      ]
    }
  }
}
