{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitGud",
  "version": "2.5.0",
  "identifier": "com.gitgud.app",
  "build": {
    "beforeDevCommand": "npm run ng:serve",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build:angular",
    "frontendDist": "../dist/gitgud"
  },
  "app": {
    "windows": [
      {
        "title": "GitGud",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  }
}
