{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "opener:default",
    "os:allow-platform",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}
