{
  "publish": {
    "provider": "github",
    "releaseType": "draft"
  },
  "asar": true,
  "directories": {
    "output": "release/"
  },
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json",
    "!node_modules/**",
    {
      "from": "../dist",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": [
    "dist/assets/monaco/**"
  ],
  "win": {
    "icon": "dist/assets/icons",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "portable": {
    "splashImage": "dist/assets/icons/electron.bmp",
    "artifactName": "${productName}-${version}-Windows-${arch}-Portable.${ext}"
  },
  "nsis": {
    "artifactName": "${productName}-${version}-Windows-${arch}-Setup.${ext}"
  },
  "mac": {
    "icon": "dist/assets/icons",
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "icon": "build/icons",
    "target": [
      "deb",
      "rpm",
      "AppImage",
      "tar.gz"
    ]
  }
}
