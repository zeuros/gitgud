{
  "publish": {
    "provider": "github",
    "releaseType": "draft"
  },
  "asar": true,
  "directories": {
    "output": "release/"
  },
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.map",
    "!package.json",
    "!package-lock.json",
    "!node_modules/**",
    {
      "from": "../dist",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": [
    "dist/assets/monaco/**"
  ],
  "win": {
    "icon": "dist/assets/icons",
    "target": [
      "portable"
    ]
  },
  "portable": {
    "splashImage": "dist/assets/icons/electron.bmp"
  },
  "mac": {
    "icon": "dist/assets/icons",
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "icon": "build/icons",
    "target": [
      "AppImage",
      "tar.gz"
    ]
  },
  "flatpak": {
    "base": "org.electronjs.Electron2.BaseApp",
    "baseVersion": "24.08",
    "runtimeVersion": "24.08",
    "runtime": "org.freedesktop.Platform",
    "sdk": "org.freedesktop.Sdk",
    "finishArgs": [
      "--share=ipc",
      "--socket=x11",
      "--socket=wayland",
      "--share=network",
      "--device=dri",
      "--filesystem=home",
      "--socket=ssh-auth",
      "--talk-name=org.freedesktop.Notifications",
      "--talk-name=org.freedesktop.portal.OpenURI",
      "--talk-name=org.freedesktop.portal.FileChooser",
      "--env=ELECTRON_OZONE_PLATFORM_HINT=auto"
    ]
  }
}
